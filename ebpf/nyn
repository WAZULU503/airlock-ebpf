use aya::{Ebpf, programs::Lsm, Btf};
use std::{thread, time::Duration};

fn main() -> Result<(), anyhow::Error> {
    // Load compiled eBPF object
    let mut bpf = Ebpf::load_file("target/bpfel-unknown-none/release/airlock-ebpf")?;

    // Get LSM program
    let program: &mut Lsm = bpf.program_mut("bprm_check_security")?.try_into()?;

    // Load with BTF (REQUIRED for LSM)
    let btf = Btf::from_sys_fs()?;
    program.load("bprm_check_security", &btf)?;

    // Attach to kernel hook
    program.attach()?;

    println!("LSM attached");

    // Keep process alive
    loop {
        thread::sleep(Duration::from_secs(60));
    }
}








